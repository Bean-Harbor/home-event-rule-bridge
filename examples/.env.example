# Discord bot token from the Discord Developer Portal.
DISCORD_BOT_TOKEN=

# Optional comma-separated channel ids. Recommended for server testing.
DISCORD_ALLOWED_CHANNEL_IDS=

# Home Assistant URL and long-lived access token.
HA_URL=http://homeassistant.local:8123
HA_TOKEN=

# Safe default: dry-run only. Keep false during the first dogfood run.
ALLOW_WRITE_AUTOMATIONS=false
HA_CONFIG_DIR=

# Optional JSONL audit log for confirmed dry-runs or writes.
BRIDGE_AUDIT_LOG=audit/home_event_rule_bridge.jsonl

# Parser profile:
# - rules-only: no model, minimal setup.
# - fast: small local model, maps to qwen3:0.6b.
# - balanced: stronger local parsing, maps to qwen3:1.7b.
# - remote-dev: OpenAI-compatible endpoint for development; entity metadata may leave this machine/LAN.
NSP_PROFILE=rules-only

# Developer override. Leave these alone when using rules-only, fast, or balanced.
NSP_PROVIDER=rules
OPENAI_COMPAT_BASE_URL=http://localhost:11434/v1
OPENAI_COMPAT_API_KEY=local
OPENAI_COMPAT_MODEL=

# Telegram is optional. Discord is the default dogfood path.
TELEGRAM_BOT_TOKEN=

# Optional comma-separated chat ids. Leave empty while testing locally.
TELEGRAM_ALLOWED_CHAT_IDS=
